{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://agentic-ai.dev/schemas/skills-graph.json",
    "title": "Skills Knowledge Graph",
    "description": "JSON Schema for validating skills knowledge graph structure",
    "type": "object",
    "required": [
        "graphType",
        "role",
        "generatedAt",
        "skills"
    ],
    "properties": {
        "graphType": {
            "type": "string",
            "const": "skills",
            "description": "Must be 'skills' for skills graphs"
        },
        "role": {
            "type": "string",
            "pattern": "^role-",
            "description": "Role identifier (e.g., role-builder, role-manager)"
        },
        "generatedAt": {
            "type": "string",
            "format": "date",
            "description": "Date when graph was generated (YYYY-MM-DD)"
        },
        "skills": {
            "type": "array",
            "description": "Array of skill nodes",
            "items": {
                "$ref": "#/definitions/skill"
            }
        }
    },
    "definitions": {
        "skill": {
            "type": "object",
            "required": [
                "id"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Unique skill identifier. Common conventions: 'skill:role:slug' (builder-style), 'skill-NNN' (numeric, domain-style), 'skills-root', 'cat-*' for categories. Pattern intentionally not enforced — schema validates structure, taxonomy is checked by validate_kg_integrity.py and reviewer judgement."
                },
                "type": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Skill node type. Common values: 'root', 'category', 'skill', 'procedure', 'script', 'workflow'. Not enum-locked — domain authors can introduce organic types as needed."
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Human-readable skill name"
                },
                "category": {
                    "type": "string",
                    "description": "Skill category"
                },
                "description": {
                    "type": "string",
                    "description": "Detailed skill description"
                },
                "path": {
                    "type": ["string", "null"],
                    "description": "Path to skill markdown file or implementation script. Common roots: 'agents/skills/', 'tasks/<task>/scripts/'. null permitted for placeholder/virtual skills (e.g. cat-* category nodes that don't have a backing file)."
                },
                "parent": {
                    "type": ["string", "null"],
                    "description": "Parent skill ID. null for root nodes."
                },
                "created": {
                    "type": "string",
                    "format": "date",
                    "description": "Creation date"
                },
                "links": {
                    "type": "object",
                    "description": "Links to other nodes",
                    "properties": {
                        "governed_by": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "uses": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "modifies": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "references": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "operates_on": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "superseded_by": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "additionalProperties": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "additionalProperties": true
        }
    }
}